{
  "name": "plugin-rescope",
  "version": "1.0.0-dev",
  "description": "Workarounds to rescope Claude Code plugins across projects",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "type": "module",
  "bin": {
    "plugin-rescope": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && npm run minify",
    "minify": "terser build/index.js -o build/index.js --module --compress --mangle",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run --passWithNoTests"
  },
  "author": "Erdem Bircan <erdem.erdembircan@gmail.com>",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "build/",
    "LICENSE"
  ],
  "keywords": [
    "claude",
    "plugin",
    "rescope"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
