flowchart TD
    A["plugin-rescope"] --> args

    subgraph args["Arguments"]
        CMD["command (add|remove)"] --> B["--scope (local|project)"] --> C["--help"] --> D["plugin_name [plugin_name ...]"]
    end

    args --> PARSE["Parse arguments"]
    PARSE --> HELP{"--help or no plugins?"}
    HELP -->|Yes| SHOW_HELP["Show help text"]
    HELP -->|No| SCOPE{"Determine scope"}

    SCOPE --> SETTINGS{"scope?"}
    SETTINGS -->|local| LOCAL_FILE[".claude/settings.local.json"]
    SETTINGS -->|project| PROJECT_FILE[".claude/settings.json"]

    LOCAL_FILE --> I
    PROJECT_FILE --> I

    I{"Is Claude installed?"}
    I -->|No| J["Show message: Claude is not installed"]
    I -->|Yes| K{"command?"}

    K -->|add| LOOP_ADD["For each plugin"]
    LOOP_ADD --> E{"Is plugin found in global config?"}
    E -->|Yes| BOTH{"Bound to project AND enabled?"}
    BOTH -->|Yes| SKIP["Show message: already configured"]
    BOTH -->|No| BOUND{"Already bound to project?"}
    BOUND -->|No| ADD_BINDING["Add project binding to global config"]
    BOUND -->|Yes| ENABLED_CHECK
    ADD_BINDING --> ENABLED_CHECK{"Already enabled in settings?"}
    ENABLED_CHECK -->|No| ENABLE["Enable plugin in project settings"]
    ENABLED_CHECK -->|Yes| RESCOPED["Show message: rescoped to project"]
    ENABLE --> RESCOPED
    E -->|No| G["Show message: not found, no workaround needed"]

    K -->|remove| LOOP_REMOVE["For each plugin"]
    LOOP_REMOVE --> IS_BOUND{"Is plugin bound to this project?"}
    IS_BOUND -->|No| NOT_RESCOPED["Show message: not rescoped to project"]
    IS_BOUND -->|Yes| L["Remove project binding from global config"]
    L --> M["Remove plugin from project settings"]

    LOOP_ADD -.->|error| ERR["Show error message, continue to next plugin"]
    LOOP_REMOVE -.->|error| ERR
